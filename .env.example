# ── Provider ────────────────────────────────────────────────────────────────
# Required. Which image provider to use: "openai" or "azure"
PROVIDER=openai

# ── OpenAI (when PROVIDER=openai) ───────────────────────────────────────────
# Required when PROVIDER=openai
OPENAI_API_KEY=sk-...

# Optional: override the base URL (e.g. for a proxy or Azure-compatible endpoint)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Azure OpenAI (when PROVIDER=azure) ──────────────────────────────────────
# Required when PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=my-gpt-image-deployment
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── MCP Server ──────────────────────────────────────────────────────────────
# Transport: "http" (default, multi-client) or "stdio" (local subprocess)
MCP_TRANSPORT=http

# HTTP port (only relevant when MCP_TRANSPORT=http)
PORT=3000

# Optional bearer token to protect the /mcp endpoint
# MCP_API_KEY=your-secret-mcp-key

# ── Image Generation Defaults ────────────────────────────────────────────────
DEFAULT_MODEL=gpt-image-1

# ── MCP Features ────────────────────────────────────────────────────────────
# Enable MCP Elicitation (interactive parameter refinement)
USE_ELICITATION=true

# Enable MCP Sampling (prompt enhancement via client LLM)
USE_SAMPLING=true

# ── Security ────────────────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=60

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
