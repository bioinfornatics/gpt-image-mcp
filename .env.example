# ── Secret Backend ──────────────────────────────────────────────────────────
# How to source API keys. Options:
#   file   (default) — read *_FILE vars from filesystem (Docker secrets, K8s, tmpfs)
#   keytar — read from OS keychain (macOS Keychain / GNOME Keyring / Windows Credential Manager)
#   env    — plain env vars only (opt-out; fine for development)
MCP_SECRET_BACKEND=file

# ── Provider ────────────────────────────────────────────────────────────────
# Required. Which image provider to use: "openai" or "azure"
PROVIDER=openai

# ── OpenAI (when PROVIDER=openai) ───────────────────────────────────────────
# Option A: plain env var (dev only — avoid in production)
OPENAI_API_KEY=sk-...
# Option B: path to a file containing the key (Docker secret, K8s secret, tmpfs)
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# Option C: OS keychain — set MCP_SECRET_BACKEND=keytar and run: bun run secret:store OPENAI_API_KEY

# Optional: override the base URL (e.g. for a proxy or Azure-compatible endpoint)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Azure OpenAI (when PROVIDER=azure) ──────────────────────────────────────
# Required when PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# Option A: plain
# AZURE_OPENAI_API_KEY=...
# Option B: file
# AZURE_OPENAI_API_KEY_FILE=/run/secrets/azure_openai_api_key
# AZURE_OPENAI_DEPLOYMENT=my-gpt-image-deployment
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── MCP Server ──────────────────────────────────────────────────────────────
# Transport: "http" (default, multi-client) or "stdio" (local subprocess)
MCP_TRANSPORT=http

# HTTP port (only relevant when MCP_TRANSPORT=http)
PORT=3000

# Optional bearer token to protect the /mcp endpoint
# Option A: plain
# MCP_API_KEY=your-secret-mcp-key
# Option B: file
# MCP_API_KEY_FILE=/run/secrets/mcp_api_key

# ── Image Generation Defaults ────────────────────────────────────────────────
DEFAULT_MODEL=gpt-image-2

# ── MCP Features ────────────────────────────────────────────────────────────
# Enable MCP Elicitation (interactive parameter refinement)
USE_ELICITATION=true

# Enable MCP Sampling (prompt enhancement via client LLM)
USE_SAMPLING=true

# ── Security ────────────────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=60

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Together AI (when PROVIDER=together) ──────────────────────────────────────
# PROVIDER=together
# TOGETHER_API_KEY=your-together-api-key
# Free model (no cost): black-forest-labs/FLUX.1-schnell-Free

# ── Custom OpenAI-compatible endpoint (when PROVIDER=custom) ──────────────────
# PROVIDER=custom
# CUSTOM_OPENAI_BASE_URL=http://localhost:11434/v1   # e.g. Ollama
# CUSTOM_OPENAI_API_KEY=none                          # optional
# CUSTOM_OPENAI_MODELS=llama3,mistral                 # comma-separated
