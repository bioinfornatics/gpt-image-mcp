# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ─── npm pack artefact ────────────────────────────────────────────────────────
*.tgz

# ─── Environment & secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Do NOT ignore .env.example — it must be committed as a template

# ─── Test & coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ─── IDE & editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── Beads issue tracker (runtime state — NOT the issue database) ─────────────
# Keep: .beads/issues.jsonl  (issue database — committed)
# Keep: .beads/config.json   (project config — committed)
# Keep: .beads/README.md     (documentation — committed)
.beads/export-state.json
.beads/interactions.jsonl
.beads/last-touched
.beads/.local_version
.beads/embeddeddolt/

# ─── Docker ───────────────────────────────────────────────────────────────────
# .dockerignore is committed — do not ignore it

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
.cache/
.temp/
tmp/
