{
  "_comment": "Add the 'mcpServers' block you need to your Claude Desktop config.",
  "_config_location_macos": "~/Library/Application Support/Claude/claude_desktop_config.json",
  "_config_location_windows": "%APPDATA%\\Claude\\claude_desktop_config.json",
  "_config_location_linux": "~/.config/Claude/claude_desktop_config.json",

  "mcpServers": {

    "gpt-image-mcp": {
      "_comment": "RECOMMENDED — bun x pulls the package automatically, no clone needed.",
      "command": "bun",
      "args": ["x", "--bun", "gpt-image-mcp"],
      "env": {
        "PROVIDER": "openai",
        "OPENAI_API_KEY": "sk-replace-with-your-key",
        "MCP_TRANSPORT": "stdio",
        "LOG_LEVEL": "error"
      }
    },

    "gpt-image-mcp-pinned": {
      "_comment": "Pin a specific version for reproducibility.",
      "command": "bun",
      "args": ["x", "--bun", "gpt-image-mcp@0.1.0"],
      "env": {
        "PROVIDER": "openai",
        "OPENAI_API_KEY": "sk-replace-with-your-key",
        "MCP_TRANSPORT": "stdio",
        "LOG_LEVEL": "error"
      }
    },

    "gpt-image-mcp-npx": {
      "_comment": "npx variant — for users without Bun installed.",
      "command": "npx",
      "args": ["-y", "gpt-image-mcp"],
      "env": {
        "PROVIDER": "openai",
        "OPENAI_API_KEY": "sk-replace-with-your-key",
        "MCP_TRANSPORT": "stdio"
      }
    },

    "gpt-image-mcp-azure": {
      "_comment": "Azure OpenAI provider via bun x.",
      "command": "bun",
      "args": ["x", "--bun", "gpt-image-mcp"],
      "env": {
        "PROVIDER": "azure",
        "AZURE_OPENAI_ENDPOINT": "https://my-resource.openai.azure.com",
        "AZURE_OPENAI_API_KEY": "replace-with-azure-key",
        "AZURE_OPENAI_DEPLOYMENT": "my-gpt-image-deployment",
        "AZURE_OPENAI_API_VERSION": "2025-04-01-preview",
        "MCP_TRANSPORT": "stdio",
        "LOG_LEVEL": "error"
      }
    },

    "gpt-image-mcp-local": {
      "_comment": "From a local clone — useful for development / unreleased changes.",
      "command": "bun",
      "args": ["run", "/absolute/path/to/gpt-image-mcp/src/main.ts"],
      "env": {
        "PROVIDER": "openai",
        "OPENAI_API_KEY": "sk-replace-with-your-key",
        "MCP_TRANSPORT": "stdio"
      }
    },

    "gpt-image-mcp-docker-http": {
      "_comment": "Connect to a running Docker container via HTTP — requires mcp-remote proxy.",
      "_note": "Claude Desktop doesn't support remote HTTP MCP servers natively. Use mcp-remote: https://github.com/geelen/mcp-remote",
      "command": "npx",
      "args": ["mcp-remote", "http://localhost:3000/mcp"],
      "env": {}
    }

  }
}
