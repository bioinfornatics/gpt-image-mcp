{
  "name": "gpt-image-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI image generation via OpenAI and Azure OpenAI gpt-image-* models",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node --max-old-space-size=8192 node_modules/.bin/tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "bun run src/main.ts",
    "start:http": "MCP_TRANSPORT=http bun run src/main.ts",
    "start:stdio": "MCP_TRANSPORT=stdio bun run src/main.ts",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "type-check": "node --max-old-space-size=8192 node_modules/.bin/tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "secret:store": "bun run src/cli/store-secret.ts",
    "secret:delete": "bun run src/cli/store-secret.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/terminus": "^10.2.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "openai": "^4.96.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "nock": "^13.5.6",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
