{
  "name": "@bioinfornatics/gpt-image-mcp",
  "version": "0.0.1",
  "description": "MCP server for AI image generation via OpenAI and Azure OpenAI gpt-image-* models",
  "license": "CECILL-2.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/bioinfornatics/gpt-image-mcp.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "bin": {
    "gpt-image-mcp": "./dist/main.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node --max-old-space-size=8192 node_modules/.bin/tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/main.js",
    "start": "node dist/main.js",
    "start:dev": "bun run src/main.ts",
    "start:http": "MCP_TRANSPORT=http bun run src/main.ts",
    "start:stdio": "MCP_TRANSPORT=stdio bun run src/main.ts",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "type-check": "node --max-old-space-size=8192 node_modules/.bin/tsc -p tsconfig.build.json --noEmit",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "secret:store": "bun run src/cli/store-secret.ts",
    "secret:delete": "bun run src/cli/store-secret.ts",
    "prepublishOnly": "bun test && bun run build",
    "publish:dry": "npm pack --dry-run",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/terminus": "^10.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^4.22.1",
    "joi": "^17.13.3",
    "openai": "^4.104.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "nock": "^13.5.6",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "overrides": {
    "multer": "^2.1.1",
    "lodash": "^4.18.1",
    "file-type": "^21.3.2",
    "@nestjs/core": "^11.1.18"
  }
}
